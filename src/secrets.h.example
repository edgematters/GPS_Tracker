#ifndef SECRETS_H
#define SECRETS_H

// Copy this file to src/secrets.h (which is gitignored) and fill in the
// values from your AWS IoT Core thing. Non-secret config (endpoint, topics,
// root CA) lives in config.h, which IS checked in.
//
// To create a fresh device cert + key:
//   1. AWS Console -> IoT Core -> Manage -> Things -> Create thing
//   2. Auto-generate a new certificate, download cert + private key
//   3. Attach a policy that allows iot:Connect / iot:Publish / iot:Receive
//      / iot:Subscribe / iot:PublishRetain on your topics
//   4. Paste the .pem contents below

// Device certificate (the .pem.crt file from AWS)
static const char DEVICE_CERT[] PROGMEM = R"EOF(
-----BEGIN CERTIFICATE-----
PASTE_YOUR_DEVICE_CERTIFICATE_HERE
-----END CERTIFICATE-----
)EOF";

// Device private key (the .pem.key file from AWS) — KEEP SECRET
static const char DEVICE_PRIVATE_KEY[] PROGMEM = R"EOF(
-----BEGIN RSA PRIVATE KEY-----
PASTE_YOUR_DEVICE_PRIVATE_KEY_HERE
-----END RSA PRIVATE KEY-----
)EOF";

#endif // SECRETS_H
